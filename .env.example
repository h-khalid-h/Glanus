# Environment Variables for Glanus Platform

# ============================================
# REQUIRED (always)
# ============================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/glanus?sslmode=disable"

# Authentication & Sessions
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
REDIS_URL="redis://localhost:6379"

# Security
CSRF_SECRET="your-csrf-secret-here-minimum-32-characters-change-in-production"
CRON_SECRET="your-cron-secret-change-in-production"

# ============================================
# REQUIRED (production only)
# ============================================

# Public URLs
NEXT_PUBLIC_APP_URL="https://glanus.example.com"
NEXT_PUBLIC_API_URL="https://glanus.example.com/api"

# Stripe Billing
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."




# ============================================
# EMAIL (configure at least one provider)
# ============================================

SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"           # true for port 465, false for 587 (STARTTLS)
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL="noreply@glanus.com"
SMTP_FROM_NAME="Glanus"


# Email — Brevo (Sendinblue) — primary
BREVO_API_KEY=""
BREVO_FROM_EMAIL="noreply@glanus.com"
BREVO_FROM_NAME="Glanus"

# Email — SendGrid (fallback when Brevo is not set)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@glanus.com"

# Alert sender address
ALERT_FROM_EMAIL="alerts@glanus.com"

# ============================================
# OPTIONAL INTEGRATIONS
# ============================================

# Sentry Error Tracking
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# OpenAI (Platform works without it)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"

# ============================================
# RUNTIME & SECURITY SETTINGS
# ============================================

NODE_ENV="development"
CONTAINER="false"                       # Set to "true" if running in Docker/EasyPanel
LOG_LEVEL="info"

# Security Settings
SESSION_TIMEOUT_HOURS=24
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
CORS_ALLOWED_ORIGINS="https://glanus.example.com"

# Agent Infrastructure
GLANUS_SSH_KEYS_PATH="/app/ssh_keys"

# Agent Downloads
NEXT_PUBLIC_AGENT_DOWNLOAD_URL="https://releases.glanus.io/agent"

# Agent & Preauth Token Secrets (optional — falls back to NEXTAUTH_SECRET / CSRF_SECRET)
AGENT_TOKEN_SECRET=""
PREAUTH_TOKEN_SECRET=""

# ============================================
# SEED / ADMIN (development & first deploy)
# ============================================

ADMIN_EMAIL=""
ADMIN_PASSWORD=""
SEED_PASSWORD=""
