#!/bin/bash
# Post-installation script for Glanus Agent
# Runs after app bundle is installed

set -e

# Install LaunchAgent
LAUNCH_AGENT_PLIST="/Library/LaunchAgents/com.glanus.agent.plist"
cp "/Applications/Glanus Agent.app/Contents/Resources/com.glanus.agent.plist" "$LAUNCH_AGENT_PLIST"

# Set permissions
chown root:wheel "$LAUNCH_AGENT_PLIST"
chmod 644 "$LAUNCH_AGENT_PLIST"

# Load LaunchAgent for the current console user if one is logged in.
# LaunchAgents run in a user GUI session; loading them in the installer/root
# context does not start the menu bar app correctly.
CONSOLE_USER=$(stat -f '%Su' /dev/console 2>/dev/null || true)

if [ -n "$CONSOLE_USER" ] && [ "$CONSOLE_USER" != "root" ] && [ "$CONSOLE_USER" != "loginwindow" ]; then
	CONSOLE_UID=$(id -u "$CONSOLE_USER")
	launchctl bootout "gui/$CONSOLE_UID" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
	launchctl bootstrap "gui/$CONSOLE_UID" "$LAUNCH_AGENT_PLIST"
	launchctl kickstart -k "gui/$CONSOLE_UID/com.glanus.agent" >/dev/null 2>&1 || true
	echo "Loaded LaunchAgent for $CONSOLE_USER"
else
	echo "No active desktop user detected; the agent will start automatically on next login"
fi

echo "Glanus Agent installed successfully"
echo "The agent will start automatically when the user signs in"

exit 0
