# Glanus Agent — Linux DEB/RPM builder
# Produces the GUI+daemon .deb (and optional .rpm) inside a clean container
# so the host doesn't need Rust, Node or Tauri system deps installed.
#
# Build context must be the `glanus-agent/` directory itself:
#   docker build -f glanus-agent/installers/linux/Dockerfile.build \
#       -t glanus-agent-build ./glanus-agent
#   docker run --rm -v "$PWD/glanus-agent/builds:/out" glanus-agent-build 0.1.0

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH=/usr/local/cargo/bin:/usr/local/nvm/versions/node/v20.18.0/bin:$PATH \
    NODE_VERSION=20.18.0

# System deps: Tauri runtime libs + build chain + packaging tools
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential curl ca-certificates pkg-config libssl-dev \
        libwebkit2gtk-4.1-dev libgtk-3-dev \
        libayatana-appindicator3-dev librsvg2-dev \
        libxdo-dev libvpx-dev \
        dpkg-dev fakeroot rpm file git \
    && rm -rf /var/lib/apt/lists/*

# Rust (stable, minimal profile)
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs \
        | sh -s -- -y --default-toolchain stable --profile minimal \
    && rustup target add x86_64-unknown-linux-gnu

# Node (via nvm-less tarball install for reproducibility)
RUN curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-x64.tar.xz" \
        -o /tmp/node.tar.xz \
    && mkdir -p /usr/local/nvm/versions/node/v${NODE_VERSION} \
    && tar -xJf /tmp/node.tar.xz -C /usr/local/nvm/versions/node/v${NODE_VERSION} --strip-components=1 \
    && rm /tmp/node.tar.xz \
    && node --version && npm --version

WORKDIR /src
COPY . /src/glanus-agent

# Warm cargo registry so repeated builds are faster (optional, best-effort)
RUN cd /src/glanus-agent/src-tauri && cargo fetch --target x86_64-unknown-linux-gnu || true

VOLUME ["/out"]

ENTRYPOINT ["/bin/bash", "-c", "\
    VERSION=\"${1:-0.1.0}\"; \
    cd /src/glanus-agent/installers/linux && \
    chmod +x build.sh && \
    ./build.sh \"$VERSION\" && \
    cp glanus-agent_${VERSION}_amd64.deb /out/ && \
    cp glanus-agent_${VERSION}_amd64.deb /out/glanus-agent.deb && \
    [ -f glanus-agent-${VERSION}-1.x86_64.rpm ] && cp glanus-agent-${VERSION}-1.x86_64.rpm /out/ || true; \
    echo; echo 'Build artifacts:'; ls -lh /out/ \
", "--"]
